<section class="u-pY-50">
  <div class="u-inner">
    <h1 class="u-title3 u-mb-30">
      <span>ジャンル一覧・追加</span>
    </h1>

    <%= form_with model: @genre, url: admin_genres_path, local: true do |f| %>
      <div class="u-pc:d-f opt-center-y u-gap-30">
        <div>
          <%= f.label :name, "ジャンル名" %>
          <%= f.text_field :name, placeholder: "ジャンル名", class: "u-form-textfield" %>
        </div>
        <div class="u-btn-wrapper u-sp:mt-20">
          <%= f.submit "新規登録", class: "u-btn u-fw-b opt-small" %>
        </div>
      </div>
    <% end %>

    <div class="u-table-1 pc:opt-full sp:opt-nowrap u-mt-50">
      <table>
        <thead>
          <tr>
            <th>ジャンル</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @genres.each do |genre| %>
            <tr>
              <td><%= genre.name %></td>
              <td>
                <%= link_to "編集する", edit_admin_genre_path(genre), class: "u-btn u-fw-b opt-small-1" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div> 
</section>