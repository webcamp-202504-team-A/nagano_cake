編集画面

<%= form_with model:@address, url: address_path(@address.id), method: :patch do |f| %>
  <%# 郵便番号(ハイフンなし) %>
  <div class="form-group">
    <%= f.label :postal_code, "郵便番号(ハイフンなし)" %>
    <%= f.text_field :postal_code %>
  </div>

  <%# 住所 %>
  <div class="form-group">
    <%= f.label :address, "住所" %>
    <%= f.text_field :address %>
  </div>

  <%# 宛名 %>
  <div class="form-group">
    <%= f.label :name, "宛名" %>
    <%= f.text_field :name %>
  </div>

  <%= f.submit "変更内容を保存" %>
<% end %>