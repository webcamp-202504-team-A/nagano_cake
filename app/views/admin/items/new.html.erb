<section class="u-pY-50">
  <div class="u-inner1">
    <h1 class="u-title3 u-mb-30">
      <span>商品新規登録</span>
    </h1>

    <div class="u-size-l">
      <%= form_with model: @item, url: admin_items_path, local: true do |f| %>
        <div class="u-field-row">
          <p class="u-field-title">商品画像</p>
          <div class="u-field">
            <%= f.file_field :image, accept: "image/*" %>
          </div>
        </div>

        <div class="u-field-row">
          <p class="u-field-title">商品名</p>
          <div class="u-field">
            <%= f.text_field :name, placeholder: "商品名", class: "u-form-textfield opt-full" %>
          </div>
        </div>

        <div class="u-field-row">
          <p class="u-field-title">商品説明</p>
          <div class="u-field">
            <%= f.text_area :introduction, placeholder: "ここに説明文を記述します", class: "u-form-textarea opt-full" %>
          </div>
        </div>

        <div class="u-field-row">
          <p class="u-field-title">ジャンル</p>
          <div class="u-field">
            <%= f.collection_select :genre_id, @genres, :id, :name, { prompt: "-- 選択してください --" }, { class: "u-form-select opt-full" } %>
          </div>
        </div>

        <div class="u-field-row">
          <p class="u-field-title">税抜価格</p>
          <div class="u-field">
            <%= f.number_field :price_without_tax, placeholder: "1000", class: "u-form-textfield" %>
            <span>円</span>
          </div>
        </div>

        <div class="u-field-row">
          <p class="u-field-title">販売ステータス</p>
          <div class="u-field">
            <%= f.radio_button :is_active, true %> <%= f.label :is_active, "販売中", value: true, class: "u-pr-30" %>
            <%= f.radio_button :is_active, false %> <%= f.label :is_active, "販売停止中", value: false %>
          </div>
        </div>

        <div class="u-btn-wrapper u-mt-30">
          <%= f.submit "新規登録", class: "u-btn u-fw-b" %>
        </div>
      <% end %>
    </div>
  </div> 
</section>