<section class="u-pY-50">
  <div class="u-inner1">
    <h1 class="u-title3 u-mb-30">
      <span>注文履歴一覧</span>
    </h1>

    <div class="u-table-1 pc:opt-full sp:opt-nowrap u-mt-50">
      <table>
        <thead>
          <tr>
            <th>購入日時</th>
            <th>購入者</th>
            <th>注文個数</th>
            <th>注文ステータス</th>
          </tr>
        </thead>
        <tbody>
          <% @orders.each do |order| %>
            <tr>
              <td><%= link_to order.created_at.strftime("%Y/%m/%d %H:%M:%S"), admin_order_path(order) %></td>
              <td><%= order.customer.last_name %> <%= order.customer.first_name %></td>
              <td><%= order.order_details.sum(:amount) %></td>
              <td><%= order.status_i18n %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="pagination">
      <%= paginate @orders %>
    </div>
  </div> 
</section>