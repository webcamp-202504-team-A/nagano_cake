<!DOCTYPE html>
<html>
  <head>
    <title>NaganoCake</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <script src="https://kit.fontawesome.com/470093f27d.js" crossorigin="anonymous"></script>
    <%= stylesheet_pack_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>
    <%= javascript_pack_tag 'application', 'data-turbolinks-track': 'reload' %>
  </head>

  <body>
    <header>
      <h2><%= link_to "LOGO", root_path %></h2>
        <% if customer_signed_in? %>
          <p>ようこそ<%= current_customer.last_name %>さん!</p>
          <%= link_to "マイページ", customers_my_page_path %>
          <%= link_to "商品一覧", items_path %>
          <%= link_to "カート", cart_items_path %>
          <%= link_to "ログアウト", destroy_customer_session_path, method: :delete %>
        <% else %>
          <%= link_to "About", about_path %>
          <%= link_to "商品一覧", items_path %>
          <%= link_to "新規登録", new_customer_registration_path %>
          <%= link_to "ログイン", new_customer_session_path %>
        <% end %>
    </header>

    <% flash.each do |message_type, message| %>
      <%= message %>
    <% end %>

    <%= yield %>
    <footer>
    </footer>
  </body>
</html>
